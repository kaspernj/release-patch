{
  "name": "release-patch",
  "version": "1.0.1",
  "description": "Bump the patch version, sync master, commit, push and publish an npm package with a single command.",
  "type": "module",
  "bin": {
    "release-patch": "bin/release-patch.js"
  },
  "files": [
    "bin"
  ],
  "scripts": {
    "all-checks": "npm run lint && npm test",
    "test": "node --test tests/*.test.js",
    "lint": "npm run eslint && npm run fallow && npm run typecheck",
    "eslint": "eslint \"bin/**/*.js\" \"tests/**/*.js\"",
    "fallow": "npm run fallow:audit",
    "fallow:audit": "fallow audit --gate new-only",
    "fallow:ci": "fallow audit --base origin/master --gate new-only --quiet",
    "release:patch": "node bin/release-patch.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "release",
    "patch",
    "version",
    "publish",
    "npm",
    "automation"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kaspernj/release-patch.git"
  },
  "author": "kasper@diestoeckels.de",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/kaspernj/release-patch/issues"
  },
  "homepage": "https://github.com/kaspernj/release-patch#readme",
  "devDependencies": {
    "@types/node": "^25.0.0",
    "eslint": "^10.0.2",
    "eslint-plugin-jsdoc": "^63.0.0",
    "fallow": "^2.94.0",
    "typescript": "^6.0.2"
  }
}
